# Roblox Studio AI Server - Environment Variables
# Copy this file to .env and fill in your API keys
# All providers are FREE to use

# Groq (fastest - free at https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (best free model - free at https://aistudio.google.com)
GEMINI_API_KEY=

# HuggingFace (many models - free at https://huggingface.co)
HF_API_KEY=

# Ollama (100% local - no key needed, just install Ollama)
OLLAMA_URL=http://localhost:11434

# Anthropic Claude (free tier - get key at https://console.anthropic.com)
CLAUDE_API_KEY=

# Mistral AI (free tier - get key at https://console.mistral.ai)
MISTRAL_API_KEY=

# DeepSeek (free tier - get key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# SambaNova (free tier - get key at https://cloud.sambanova.ai)
SAMBANOVA_API_KEY=

# Server port
PORT=3636
