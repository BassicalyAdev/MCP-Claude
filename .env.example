# Roblox Studio AI Server - Environment Variables
# Copy this file to .env and fill in your API keys
# All providers are FREE to use

# Groq (fastest - free at https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (best free model - free at https://aistudio.google.com)
GEMINI_API_KEY=

# HuggingFace (many models - free at https://huggingface.co)
HF_API_KEY=

# Ollama (100% local - no key needed, just install Ollama)
OLLAMA_URL=http://localhost:11434

# Server port
PORT=3636
